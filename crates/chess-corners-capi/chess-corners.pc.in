prefix=${pcfiledir}/@CC_PC_RELDIR@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: chess-corners
Description: Stable C ABI for the chess-corners detector
URL: https://github.com/vitalyvorobyev/chess-corners-rs
Version: @CC_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lchess_corners_capi
Libs.private: @CC_PC_PRIVATE_LIBS@
